{
	"custom/separator": {
		"format": "|",
		"tooltip": false
	},
	"custom/arch": {
		"format": "у°Ј‡",
		"on-click": "kitty -e sh -c 'fastfetch && sleep 1'",
		"tooltip": true,
		"tooltip-format": "I use Arch,btw"
	},
	"niri/workspaces": {
		"disable-scroll": true,
		"all-outputs": false,
		"warp-on-scroll": false,
		"format": "{icon}  {value}",
		"format-icons": {
			"urgent": "пЃЄ",
			"active": "п†’",
			"default": "п„‘"
		}
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "пЃ® ",
			"deactivated": "пЃ° "
		}
	},
	"custom/rofi": {
		"format": " Finder ",
		"on-click": "~/.config/rofi/launchers/type-5/launcher.sh",
		"tooltip": false
	},
	"custom/_files": {
		"format": " Files ",
		"on-click": "kitty bash ranger",
		"tooltip": false
	},
	"custom/edit": {
		"format": " Edit ",
		"on-click": "kitty bash -c 'nvim'",
		"tooltip": false
	},
	"custom/help": {
		"format": " Help ",
		"on-click": "firefox --new-window https://github.com/SydX-pages/dotfiles/blob/main/README.md",
		"tooltip": false
	},
	"custom/todo": {
		"format": "  п‚® \u00a0{} ",
		"exec": "~/.config/waybar/scripts/todo/todo.sh",
		"on-double-click": "~/.config/waybar/scripts/todo/todo.sh mark_done",
		"on-click-right": "~/.config/waybar/scripts/todo/todo.sh open_tui",
		"on-click-middle": "~/.config/waybar/scripts/todo/todo.sh middle_click",
		"return-type": "json",
		"interval": 5,
		"tooltip": true
	},
	"custom/countdown": {
		"exec": "~/.config/waybar/scripts/countdown/countdown.sh",
		"return-type": "json",
		"format": " {}    ",
		"interval": 3600,
		"on-click-right": "kitty bash ~/.config/waybar/scripts/countdown/countdown.sh interactive",
		"on-scroll-up": "~/.config/waybar/scripts/countdown/countdown.sh scroll-up",
		"on-scroll-down": "~/.config/waybar/scripts/countdown/countdown.sh scroll-down",
		"scroll-step": 0.1
	},
	"clock": {
		"format": " {:%H:%M:%S - %e %b} ",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"format-alt": "\t{:%Y-%m-%d}\t",
		"interval": 1
	},
	"backlight": {
		"device": "intel_backlight",
		"format": "{icon} {percent}% ",
		"format-icons": [
			"у±©Ћ ",
			"у±©Џ ",
			"у±©‘ ",
			"у±©’ ",
			"у±©“ ",
			"у±©” ",
			"у±©– "
		],
		"scroll-step": 0.15,
		"on-click": "brightnessctl -d tpacpi::kbd_backlight set 1+",
		"on-click-right": "brightnessctl -d tpacpi::kbd_backlight set 1-"
	},
	"wlr/taskbar": {
		"format": "{icon}",
		"icon-size": 32,
		"spacing": 3,
		"on-click-middle": "close",
		"tooltip-format": "{title}",
		"ignore-list": [],
		"on-click": "activate"
	},
	"niri/window": {
		"format": "{title}",
		"icon": true,
		"icon-size": 30,
		"rewrite": {}
	},
	"pulseaudio": {
		"format": " {icon}  {volume}% ",
		"format-bluetooth": "{icon} {volume}% пЉ” {format_source} ",
		"format-bluetooth-muted": "пљ© {icon}пЉ” {format_source} ",
		"format-muted": "о»Ё {format_source} ",
		"format-source": "п„° {volume}%",
		"format-source-muted": "п„± ",
		"format-icons": {
			"headphone": "пЂҐ ",
			"phone": "п‚• ",
			"portable": "п‚• ",
			"car": "п†№ ",
			"default": [
				"пЂ¦ ",
				"пЂ§ ",
				"у°•ѕ ",
				"пЂЁ "
			]
		},
		"scroll-step": 0.15,
		"on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
		"on-click-right": "pavucontrol"
	},
	"bluetooth": {
		"format": " пЉ” {status} ",
		"format-connected": " пЉ” connected ",
		"tooltip-format": " {controller_alias}\t{controller_address}\n\n{num_connections} connected ",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
		"on-click": "sh ~/Custom/Apps/rofi-bluetooth/rofi-bluetooth",
		"on-click-right": "sh ~/Custom/Apps/rofi-bluetooth/ctl.sh"
	},
	"network": {
		"format-wifi": " п‡«   {essid} ({signalStrength}%) ",
		"format-ethernet": "{ipaddr}/{cidr} у°©  ",
		"tooltip-format": "{ifname} ip {ipaddr} у°©  ",
		"format-linked": "{ifname} (No IP) у°©  ",
		"format-disconnected": "Disconnected вљ  ",
		"on-click": "sh ~/Custom/Apps//rofi-wifi-menu/rofi-wifi-menu.sh",
		"on-click-right": "sh ~/Custom/Apps/rofi-wifi-menu/nmtui.sh"
	},
	"custom/vpn": {
		"format": "VPN {text}",
		"return-type": "json",
		"exec": "/home/sydx/.local/bin/ts_state.sh",
		"interval": 1,
		"on-click": "/home/sydx/.local/bin/ts_toggle.sh"
	},
	"temperature": {
		"interval": 10,
		"hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
		"critical-threshold": 100,
		"format-critical": "п‹‡ {temperatureC}",
		"format": "п‹‰ {temperatureC}В°C "
	},
	"niri/language": {
		"format": "п‚¬  {} ",
		"format-en": "EN",
		"format-zh": "CN"
	},
	"privacy": {
		"icon-spacing": 4,
		"icon-size": 18,
		"transition-duration": 250,
		"modules": [
			{
				"type": "screenshare",
				"tooltip": true,
				"tooltip-icon-size": 24
			},
			{
				"type": "audio-out",
				"tooltip": true,
				"tooltip-icon-size": 24
			},
			{
				"type": "audio-in",
				"tooltip": true,
				"tooltip-icon-size": 24
			}
		]
	},
	"tray": {
		"icon-size": 18,
		"spacing": 10
	},
	"custom/weather": {
		"exec": "wttrbar",
		"format": "Weather {} ",
		"return-type": "json",
		"interval": "3600",
		"on-click-right": "firefox --new-window https://wttr.in"
	},
	"battery": {
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{icon}  {capacity}% ",
		"format-full": "{icon}  {capacity}% ",
		"format-charging": "п—§  {capacity}% ",
		"format-plugged": "п‡¦  {capacity}% ",
		"format-alt": "{time}  {icon} ",
		"format-icons": [
			"п‰„",
			"п‰ѓ",
			"п‰‚",
			"п‰Ѓ",
			"п‰Ђ"
		]
	},
	"battery#bat2": {
		"bat": "BAT2"
	},
	"image#files": {
		"path": "/usr/share/icons/hicolor/128x128/apps/org.xfce.thunar.png",
		"size": 32,
		"on-click": "Thunar"
	},
	"image#browser": {
		"path": "/usr/share/icons/hicolor/256x256/apps/firefox.png",
		"size": 32,
		"on-click": "firefox"
	},
	"image#terminal": {
		"path": "/usr/share/icons/hicolor/256x256/apps/kitty.png",
		"size": 36,
		"on-click": "kitty"
	},
	"image#qq": {
		"path": "/home/sydx/.local/share/icons/tencent/QQ.svg",
		"size": 36,
		"on-click": "qq"
	},
	"image#wechat": {
		"path": "/home/sydx/.local/share/icons/tencent/wechat.svg",
		"size": 32,
		"on-click": "wechat"
	},
	"custom/power": {
		"format": " вЏ» ",
		"on-click": "~/.config/polybar/scripts/powermenu.sh &",
		"tooltip-format": "PowerMenu"
	}
}
